# Copy to `.env` on the server (next to docker-compose.yml) and fill in.
# docker compose reads this file automatically.

# Public URL of the collaboration websocket, served by nginx (/collab). Baked into
# the client at build time. Leave empty to ship without realtime collaboration.
NEXT_PUBLIC_COLLAB_WS_URL=wss://your-domain.example/collab

# Where the client fetches the dataset manifest from (usually the default is fine).
NEXT_PUBLIC_GTNH_DATASET_MANIFEST_URL=/datasets/gtnh/datasets.manifest.json

# The dataset is downloaded and baked into the app image at build time (see
# DATASET_SOURCE / DATASET_VERSION below), so no proxy is needed. Leave this empty.
# Set a URL only to override the baked-in dataset and proxy from another deployment.
GTNH_DATASET_BACKEND_URL=

# Which dataset to bake into the image (defaults are fine).
DATASET_SOURCE=https://dev-gtnh.samiracle.fr
DATASET_VERSION=stable-2.8.4
