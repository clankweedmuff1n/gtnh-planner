# Host nginx reverse proxy for the GTNH Factory Flow stack.
# Place at /etc/nginx/sites-available/gtnh-factory-flow.conf, symlink into
# sites-enabled, replace your-domain.example, then run certbot for TLS:
#   sudo certbot --nginx -d your-domain.example
#
# certbot rewrites this to add the listen 443 / SSL block and an HTTP->HTTPS redirect.

server {
    listen 80;
    server_name your-domain.example;

    # Realtime collaboration websocket -> collab container.
    location /collab {
        proxy_pass http://127.0.0.1:1234;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        # Critical for websockets: without this nginx buffers frames and the Yjs sync
        # step stalls (awareness still trickles through, document updates arrive late).
        proxy_buffering off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # Everything else -> Next.js app container.
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
